<!doctype html>
<html>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title><%= form.title %></title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <header class="site-header">
    <div class="container">
      <h1 class="brand"><a href="/">Simple Survey App</a></h1>
      <nav class="nav">
        <a class="btn" href="/create">Create</a>
      </nav>
    </div>
  </header>

  <main class="container">
    <section class="card">
      <h2><%= form.title %></h2>
      <p class="muted">Shareable link: <a href="<%= shareUrl %>"><%= shareUrl %></a></p>

      <% if (form.embed && (form.embed.html || form.embed.url)) { %>
        <div class="embed-wrap">
          <% if (form.embed.html) { %>
            <%- form.embed.html %>
          <% } else { %>
            <iframe src="<%= form.embed.url %>" class="embed-iframe"></iframe>
          <% } %>
        </div>
        <p class="muted">This is an embedded external form. Responses are collected by the provider.</p>
      <% } else { %>
        <form method="post" action="/submit/<%= form.id %>">
          <% form.questions.forEach((q, idx) => { %>
            <label class="field"><span class="qtext"><%= q %></span>
              <input type="text" name="q_<%= idx %>">
            </label>
          <% }) %>
          <div class="actions">
            <button class="btn primary" type="submit">Submit</button>
            <a class="btn" href="/results/<%= form.id %>">View results</a>
          </div>
        </form>
      <% } %>

      <p class="muted"><a href="/">Back</a></p>
    </section>
  </main>

</body>
</html>
