<!doctype html>
<html>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Create Survey</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <header class="site-header">
    <div class="container">
      <h1 class="brand"><a href="/">Simple Survey App</a></h1>
      <nav class="nav">
        <a class="btn" href="/">Home</a>
      </nav>
    </div>
  </header>

  <main class="container">
    <section class="card">
      <h2>Create a Survey / Form</h2>
      <form method="post" action="/create">
        <label class="field">Title<br><input name="title" class="input" placeholder="Survey title"></label>
        <div class="field">
          <label><input type="radio" name="mode" value="local" id="mode_local" checked> <span>Local form (questions below)</span></label>
          <label><input type="radio" name="mode" value="embed" id="mode_embed"> <span>Embed external form (paste iframe or URL)</span></label>
        </div>

        <div id="local_fields">
          <label class="field">Questions (one per line or comma-separated)<br>
            <textarea name="questions" rows="6" class="input" placeholder="Question 1\nQuestion 2\nQuestion 3"></textarea>
          </label>
        </div>

        <div id="embed_fields" style="display:none">
          <label class="field">Embed HTML (paste iframe or script block)<br>
            <textarea name="embedHtml" rows="6" class="input" placeholder="<iframe src=...></iframe>"></textarea>
          </label>
          <label class="field">Or Embed URL (paste a URL to use in an iframe)<br>
            <input name="embedUrl" class="input" placeholder="https://form.typeform.com/to/...">
          </label>
        </div>
        <div class="actions"><button class="btn primary" type="submit">Create</button></div>
      </form>
      <p class="muted"><a href="/">Back</a></p>
    </section>
  </main>
  <script>
    const modeLocal = document.getElementById('mode_local');
    const modeEmbed = document.getElementById('mode_embed');
    const localFields = document.getElementById('local_fields');
    const embedFields = document.getElementById('embed_fields');
    function updateMode(){
      if (modeEmbed.checked){
        localFields.style.display = 'none';
        embedFields.style.display = 'block';
      } else {
        localFields.style.display = 'block';
        embedFields.style.display = 'none';
      }
    }
    modeLocal.addEventListener('change', updateMode);
    modeEmbed.addEventListener('change', updateMode);
    updateMode();
  </script>
</body>
</html>
