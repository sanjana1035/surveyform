<!doctype html>
<html>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Simple Survey App</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <header class="site-header">
    <div class="container">
      <h1 class="brand"><a href="/">Simple Survey App</a></h1>
      <nav class="nav">
        <a class="btn" href="/create">Create</a>
      </nav>
    </div>
  </header>

  <main class="container">
    <section class="card">
      <h2>Surveys &amp; Forms</h2>
      <% if (forms.length===0) { %>
        <p>No surveys yet. Create one to get started.</p>
      <% } else { %>
        <ul class="list">
          <% forms.forEach(f => { %>
            <li class="list-item">
              <div>
                <strong><a href="/form/<%= f.id %>"><%= f.title %></a></strong>
              </div>
              <div class="muted"><a href="/results/<%= f.id %>">Results</a></div>
            </li>
          <% }) %>
        </ul>
      <% } %>
    </section>
  </main>

</body>
</html>
