<!doctype html>
<html>
<head>
  <meta charset="utf-8" />
  <title>Simple Survey App</title>
  <style>body{font-family:Arial,Helvetica,sans-serif;max-width:800px;margin:30px auto;padding:0 16px}a{color:#0066cc}</style>
</head>
<body>
  <h1>Surveys & Forms</h1>
  <p><a href="/create">Create a new survey</a></p>
  <% if (forms.length===0) { %>
    <p>No surveys yet. Create one to get started.</p>
  <% } else { %>
    <ul>
      <% forms.forEach(f => { %>
        <li>
          <strong><a href="/form/<%= f.id %>"><%= f.title %></a></strong>
          — <a href="/results/<%= f.id %>">Results</a>
        </li>
      <% }) %>
    </ul>
  <% } %>
</body>
</html>
